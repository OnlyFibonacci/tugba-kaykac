<!DOCTYPE html>
<html class="light" lang="{{ locale }}">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>{{ t.meta[titleKey] }}</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&amp;family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "tertiary-fixed": "#c6e7fe",
                    "outline-variant": "#c4c6d0",
                    "surface-dim": "#d8dadd",
                    "outline": "#74777f",
                    "primary-fixed-dim": "#adc7f8",
                    "on-tertiary-fixed": "#001e2d",
                    "surface-container-highest": "#e0e3e6",
                    "on-error-container": "#93000a",
                    "error-container": "#ffdad6",
                    "on-tertiary-fixed-variant": "#2b4a5d",
                    "on-primary-fixed": "#001b3d",
                    "error": "#ba1a1a",
                    "surface-container-low": "#f2f4f7",
                    "surface-container-lowest": "#ffffff",
                    "on-primary-fixed-variant": "#2c4770",
                    "on-tertiary": "#ffffff",
                    "secondary-fixed-dim": "#7ed4db",
                    "surface-bright": "#f7f9fc",
                    "primary": "#001736",
                    "secondary-container": "#9af0f8",
                    "surface-tint": "#455f8a",
                    "primary-fixed": "#d6e3ff",
                    "on-primary": "#ffffff",
                    "on-surface": "#191c1e",
                    "on-secondary-container": "#007076",
                    "background": "#f7f9fc",
                    "inverse-on-surface": "#eff1f4",
                    "primary-container": "#0d2c54",
                    "on-secondary-fixed-variant": "#004f54",
                    "tertiary-container": "#0c2f40",
                    "surface-container-high": "#e6e8eb",
                    "on-secondary-fixed": "#002022",
                    "on-surface-variant": "#43474e",
                    "surface-variant": "#e0e3e6",
                    "tertiary": "#001a27",
                    "on-tertiary-container": "#7897ac",
                    "on-secondary": "#ffffff",
                    "secondary-fixed": "#9af0f8",
                    "inverse-surface": "#2d3133",
                    "on-error": "#ffffff",
                    "on-background": "#191c1e",
                    "surface": "#f7f9fc",
                    "inverse-primary": "#adc7f8",
                    "on-primary-container": "#7a94c2",
                    "tertiary-fixed-dim": "#abcbe1",
                    "secondary": "#00696f",
                    "surface-container": "#eceef1"
            },
            "borderRadius": {
                    "DEFAULT": "0.125rem",
                    "lg": "0.25rem",
                    "xl": "0.5rem",
                    "full": "0.75rem"
            },
            "fontFamily": {
                    "headline": ["Manrope"],
                    "body": ["Inter"],
                    "label": ["Inter"]
            }
          },
        }
      }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        .technical-grid {
            background-image: radial-gradient(circle, #001736 1px, transparent 1px);
            background-size: 32px 32px;
            opacity: 0.03;
        }
        .blueprint-grid {
            background-image: radial-gradient(circle, #001736 1px, transparent 1px);
            background-size: 30px 30px;
        }
        .blueprint-grid-contact {
            background-size: 40px 40px;
            background-image: radial-gradient(circle, #c4c6d0 1px, transparent 1px);
            opacity: 0.15;
        }
        .glass-panel {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(12px);
        }
        .sr-only {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap;
            border: 0;
        }
    </style>
</head>
<body class="bg-surface text-on-surface font-body selection:bg-secondary-container selection:text-on-secondary-container">
{% include "header.njk" %}
{{ content | safe }}
{% include "footer.njk" %}
<script>
(function () {
  document.querySelectorAll("[data-site-year]").forEach(function (el) {
    el.textContent = String(new Date().getFullYear());
  });
  var root = document.querySelector("[data-mobile-nav-root]");
  var toggle = document.querySelector("[data-mobile-nav-toggle]");
  var backdrop = document.querySelector("[data-mobile-nav-backdrop]");
  var drawer = document.querySelector("[data-mobile-nav-drawer]");
  if (!root || !toggle || !backdrop || !drawer) return;
  function openNav() {
    root.classList.remove("pointer-events-none");
    root.removeAttribute("hidden");
    backdrop.classList.remove("opacity-0");
    drawer.classList.remove("translate-x-full");
    toggle.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }
  function closeNav() {
    backdrop.classList.add("opacity-0");
    drawer.classList.add("translate-x-full");
    toggle.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
    window.setTimeout(function () {
      root.classList.add("pointer-events-none");
      root.setAttribute("hidden", "");
    }, 300);
  }
  toggle.addEventListener("click", function () {
    if (toggle.getAttribute("aria-expanded") === "true") closeNav();
    else openNav();
  });
  backdrop.addEventListener("click", closeNav);
  drawer.querySelectorAll("a").forEach(function (a) {
    a.addEventListener("click", closeNav);
  });
})();
</script>
</body>
</html>
