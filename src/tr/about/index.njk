---
layout: base.njk
locale: tr
pageId: about
titleKey: aboutTitle
permalink: /tr/about/index.html
---
{% set prefix = "/tr" %}
<main class="pt-28 md:pt-32">
<section class="relative bg-primary overflow-hidden py-24 md:py-32">
<div class="absolute inset-0 opacity-10 blueprint-grid"></div>
<div class="max-w-7xl mx-auto px-6 relative z-10">
<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
<div class="lg:col-span-7">
<span class="inline-block bg-secondary text-on-secondary px-4 py-1 text-xs font-bold tracking-[0.2em] uppercase mb-6 rounded-sm">{{ t.about.hero.badge }}</span>
<h1 class="font-headline text-5xl md:text-7xl font-extrabold text-white leading-none tracking-tighter mb-8">{{ t.about.hero.title }}</h1>
<p class="text-on-primary-container text-lg md:text-xl max-w-2xl font-light leading-relaxed">{{ t.about.hero.lead }}</p>
</div>
<div class="lg:col-span-5 relative">
<div class="absolute -top-4 -left-4 w-24 h-24 border-t-2 border-l-2 border-secondary/30"></div>
<div class="absolute -bottom-4 -right-4 w-24 h-24 border-b-2 border-r-2 border-secondary/30"></div>
<img alt="{{ t.about.hero.imageAlt }}" class="w-full aspect-[4/5] object-cover rounded shadow-2xl grayscale hover:grayscale-0 transition-all duration-700" src="/images/engineering-blueprint.png"/>
</div>
</div>
</div>
</section>
<section class="bg-surface py-24">
<div class="max-w-7xl mx-auto px-6">
<div class="max-w-3xl mx-auto space-y-8">
<h2 class="font-headline text-3xl font-bold text-primary tracking-tight">{{ t.about.mission.title }}</h2>
<div class="prose prose-slate max-w-none">
<p class="text-on-surface-variant leading-relaxed">{{ t.about.mission.p1 | safe }}</p>
<p class="text-on-surface-variant leading-relaxed mt-4">{{ t.about.mission.p2 | safe }}</p>
</div>
</div>
</div>
</section>
<section class="bg-surface-container-lowest py-24 relative overflow-hidden">
<div class="max-w-7xl mx-auto px-6">
<div class="mb-16">
<h3 class="text-sm font-bold uppercase tracking-[0.3em] text-secondary mb-2">{{ t.about.values.kicker }}</h3>
<h2 class="font-headline text-4xl font-black text-primary">{{ t.about.values.title }}</h2>
</div>
<div class="grid grid-cols-1 md:grid-cols-12 gap-6 h-auto md:h-[600px]">
<div class="md:col-span-8 bg-primary-container p-12 flex flex-col justify-end group hover:bg-primary transition-colors duration-500">
<span class="material-symbols-outlined text-secondary text-5xl mb-6" style="font-variation-settings: 'FILL' 1;">architecture</span>
<h4 class="text-white text-3xl font-bold mb-4">{{ t.about.values.precisionTitle }}</h4>
<p class="text-on-primary-container text-lg max-w-md">{{ t.about.values.precisionBody }}</p>
</div>
<div class="md:col-span-4 bg-surface-container-high p-8 flex flex-col items-center justify-center text-center">
<span class="material-symbols-outlined text-primary text-5xl mb-4" style="font-variation-settings: 'FILL' 1;">verified</span>
<h4 class="text-primary text-xl font-bold uppercase tracking-widest mb-2">{{ t.about.values.reliabilityTitle }}</h4>
<p class="text-on-surface-variant text-sm">{{ t.about.values.reliabilityBody }}</p>
</div>
<div class="md:col-span-4 bg-secondary-container p-8 flex flex-col justify-between">
<h4 class="text-on-secondary-container text-xl font-bold uppercase tracking-widest">{{ t.about.values.innovationTitle }}</h4>
<div>
<span class="material-symbols-outlined text-secondary text-6xl opacity-20">precision_manufacturing</span>
<p class="text-on-secondary-container text-sm mt-4">{{ t.about.values.innovationBody }}</p>
</div>
</div>
<div class="md:col-span-8 bg-surface-container p-12 flex items-center gap-12">
<div class="hidden sm:block">
<span class="material-symbols-outlined text-primary text-7xl">public</span>
</div>
<div>
<h4 class="text-primary text-3xl font-bold mb-2">{{ t.about.values.globalTitle }}</h4>
<p class="text-on-surface-variant">{{ t.about.values.globalBody }}</p>
</div>
</div>
</div>
</div>
</section>
<section class="py-24 bg-surface">
<div class="max-w-7xl mx-auto px-6">
<div class="bg-primary rounded-lg p-12 md:p-20 relative overflow-hidden flex flex-col md:flex-row items-center justify-between gap-12">
<div class="absolute inset-0 opacity-5 blueprint-grid"></div>
<div class="relative z-10 text-center md:text-left max-w-2xl">
<h2 class="font-headline text-3xl md:text-5xl font-bold text-white mb-6">{{ t.about.cta.title }}</h2>
<p class="text-on-primary-container text-lg">{{ t.about.cta.body }}</p>
</div>
<div class="relative z-10 shrink-0">
<a href="{{ prefix }}/contact/" class="inline-block bg-white text-primary font-bold px-10 py-4 rounded-sm tracking-wider uppercase hover:bg-secondary-container hover:text-on-secondary-container transition-all duration-300">{{ t.about.cta.button }}</a>
</div>
</div>
</div>
</section>
</main>
