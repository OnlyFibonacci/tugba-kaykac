---
layout: base.njk
locale: en
pageId: home
titleKey: homeTitle
permalink: /en/index.html
---
{% set prefix = "/en" %}
<main>
<section class="relative min-h-[921px] flex items-center pt-20 overflow-hidden bg-primary">
<div class="absolute inset-0 opacity-40">
<img alt="{{ t.home.hero.heroImgAlt }}" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAwmEgJPG9wGAUU8AeI3yfQN2BEUMm1HxxYabLRnuN86pcSy0TNO_pwrSlZJQ8yrU1RO_v56U24Uv_xwSqcFfPiY0JC7bTO7VSsH6DCkfa2Cq7F1XIxROjqcRz54OsY3QxuR6EdLWrAmbkgftxLNoQpl-PARIsGwKzO4Atc6PYsAkRNqNrrDtklndhh5nBTEhLycU2YUufHKg4E0YF4O5qHrHHuCM3g6jnku1an_DCnYsrki6RVYZbmEucy4MGCpk2464202kmMYvkO"/>
</div>
<div class="absolute inset-0 bg-gradient-to-r from-primary via-primary/80 to-transparent"></div>
<div class="relative max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-12 gap-8 items-center">
<div class="md:col-span-8 lg:col-span-7 py-12">
<div class="inline-flex items-center gap-2 mb-6 px-3 py-1 bg-secondary/20 border border-secondary/30 rounded-sm">
<span class="material-symbols-outlined text-secondary-fixed text-sm" data-icon="precision_manufacturing">precision_manufacturing</span>
<span class="text-[10px] font-label font-bold tracking-[0.2em] text-secondary-fixed uppercase">{{ t.home.hero.badge }}</span>
</div>
<h1 class="text-5xl md:text-7xl font-headline font-extrabold text-white tracking-tight leading-[1.1] mb-6">{{ t.home.hero.titleHtml | safe }}</h1>
<p class="text-lg md:text-xl text-slate-300 font-body max-w-2xl mb-10 leading-relaxed">
{{ t.home.hero.lead }}
<span class="block mt-2 text-sm opacity-60 italic font-medium">{{ t.home.hero.leadSecondary }}</span>
</p>
<div class="flex flex-wrap gap-4">
<a href="#services" class="inline-flex bg-secondary text-white px-8 py-4 font-headline font-bold uppercase tracking-wider text-sm hover:bg-secondary/90 transition-all shadow-xl shadow-secondary/10 items-center gap-3">{{ t.home.hero.ctaPrimary }}<span class="material-symbols-outlined" data-icon="arrow_forward">arrow_forward</span></a>
<a href="{{ prefix }}/contact/" class="inline-flex border border-white/20 text-white px-8 py-4 font-headline font-bold uppercase tracking-wider text-sm hover:bg-white/5 transition-all items-center">{{ t.home.hero.ctaSecondary }}</a>
</div>
</div>
</div>
<div class="absolute bottom-0 right-0 w-1/3 h-full hidden lg:block opacity-10 pointer-events-none">
<div class="technical-grid w-full h-full border-l border-t border-white/20"></div>
</div>
</section>
<section id="services" class="py-24 bg-surface relative overflow-hidden">
<div class="max-w-7xl mx-auto px-6 relative z-10">
<div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
<div>
<h2 class="text-3xl md:text-4xl font-headline font-extrabold text-primary mb-4">{{ t.home.servicesSection.title }}</h2>
<p class="text-on-surface-variant max-w-xl">{{ t.home.servicesSection.subtitle }} <span class="text-xs opacity-70 block">{{ t.home.servicesSection.subtitleSecondary }}</span></p>
</div>
<div class="h-px flex-grow bg-outline-variant/30 mx-8 hidden md:block mb-4"></div>
<div class="text-right">
<span class="text-6xl font-headline font-black text-outline-variant/10">{{ t.home.servicesSection.counter }}</span>
</div>
</div>
<div class="grid grid-cols-1 md:grid-cols-3 gap-0 border border-outline-variant/20">
{% for card in t.home.servicesSection.cards %}
<div class="group relative {% if loop.index == 2 %}bg-surface-container-low{% else %}bg-surface-container-lowest{% endif %} p-10 border-b md:border-b-0 {% if not loop.last %}md:border-r{% endif %} border-outline-variant/20 hover:bg-primary transition-colors duration-500">
<div class="mb-8 text-secondary group-hover:text-secondary-fixed transition-colors">
<span class="material-symbols-outlined text-5xl" data-icon="{{ card.icon }}">{{ card.icon }}</span>
</div>
<h3 class="text-xl font-headline font-bold mb-4 text-primary group-hover:text-white uppercase tracking-tight">{{ card.title }}</h3>
<p class="text-on-surface-variant group-hover:text-slate-400 text-sm leading-relaxed mb-6">{{ card.body }}</p>
<div class="pt-6 border-t border-outline-variant/20 group-hover:border-white/10">
<span class="text-[10px] font-label font-bold tracking-widest text-secondary group-hover:text-secondary-fixed uppercase">{{ card.footer }}</span>
</div>
</div>
{% endfor %}
</div>
</div>
</section>
<section class="py-24 bg-surface-container-low relative overflow-hidden">
<div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
<div class="relative order-2 lg:order-1">
<div class="aspect-[4/5] bg-surface-container-high relative overflow-hidden border border-outline-variant/20">
<img alt="{{ t.home.aboutPreview.imageAlt }}" class="w-full h-full object-cover grayscale opacity-80 hover:grayscale-0 transition-all duration-700" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBsptRRGt_IK7yMVGYwPww_hbE83aR5jWM8U5MwLt9o57du00BzhRuF8TJJs-V-rJSnrMtYsWRfF1APk2MkTqIjbtbhAODUbOlrcm5-AOKWvzLtL8P1mI6eZVh7ggyH7YF4nVOaDHkSW2TxoziE67zRcPPItRxs6C-JmNyqp7C3XnYLBKn_CWZkJ_ire9VDrqyif8LTNoYpk7GGPeeuB9vAREXDXT6xKAZQyi76nkc42_m0mXIzRTpfzF94OOMl2UNpGcpqoLXFaQIR"/>
<div class="absolute inset-0 bg-primary/10 mix-blend-multiply"></div>
</div>
<div class="absolute -bottom-6 -right-6 w-48 h-48 bg-secondary/10 backdrop-blur-sm border border-secondary/20 p-6 hidden md:block">
<div class="w-full h-full technical-grid opacity-30"></div>
<span class="absolute bottom-4 left-4 text-[10px] font-label font-black tracking-widest text-primary uppercase">{{ t.home.aboutPreview.refLabel }}</span>
</div>
</div>
<div class="order-1 lg:order-2">
<div class="mb-8">
<span class="text-secondary font-headline font-extrabold tracking-widest text-sm uppercase">{{ t.home.aboutPreview.kicker }}</span>
<h2 class="text-4xl md:text-5xl font-headline font-extrabold text-primary mt-4 mb-6 leading-tight">{{ t.home.aboutPreview.title }}</h2>
<div class="w-20 h-1.5 bg-secondary mb-8"></div>
</div>
<div class="space-y-6">
<p class="text-on-surface font-body text-lg leading-relaxed">{{ t.home.aboutPreview.body }}</p>
<p class="text-on-surface-variant font-body italic border-l-4 border-secondary/30 pl-6">{{ t.home.aboutPreview.quote }}</p>
</div>
<div class="mt-12 grid grid-cols-2 gap-8">
<div>
<div class="text-3xl font-headline font-black text-primary mb-1">{{ t.home.aboutPreview.stat1Value }}</div>
<div class="text-xs font-label uppercase tracking-wider text-on-surface-variant">{{ t.home.aboutPreview.stat1Label }}</div>
</div>
<div>
<div class="text-3xl font-headline font-black text-primary mb-1">{{ t.home.aboutPreview.stat2Value }}</div>
<div class="text-xs font-label uppercase tracking-wider text-on-surface-variant">{{ t.home.aboutPreview.stat2Label }}</div>
</div>
</div>
</div>
</div>
</section>
<section class="py-24 bg-primary text-white relative overflow-hidden">
<div class="absolute inset-0 technical-grid opacity-5"></div>
<div class="max-w-7xl mx-auto px-6 relative z-10 text-center">
<span class="material-symbols-outlined text-6xl text-secondary-fixed/40 mb-6" data-icon="language">language</span>
<h2 class="text-4xl md:text-6xl font-headline font-extrabold mb-8 tracking-tighter">{{ t.home.partners.title }}</h2>
<p class="text-xl text-slate-300 max-w-2xl mx-auto mb-16 font-body">{{ t.home.partners.lead }}</p>
<div class="grid grid-cols-2 md:grid-cols-4 gap-8 opacity-60">
{% for region in t.home.partners.regions %}
<div class="flex flex-col items-center">
<span class="text-2xl font-headline font-bold mb-2">{{ region }}</span>
<div class="h-px w-8 bg-secondary-fixed"></div>
</div>
{% endfor %}
</div>
</div>
</section>
</main>
