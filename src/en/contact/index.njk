---
layout: base.njk
locale: en
pageId: contact
titleKey: contactTitle
permalink: /en/contact/index.html
---
<main class="pt-24">
<section class="relative min-h-[614px] flex items-center overflow-hidden bg-primary-container">
<div class="absolute inset-0 blueprint-grid blueprint-grid-contact"></div>
<div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-12 gap-8 relative z-10 py-20">
<div class="md:col-span-7 flex flex-col justify-center">
<span class="font-label text-secondary-fixed tracking-[0.2em] uppercase font-bold text-sm mb-4">{{ t.contact.hero.kicker }}</span>
<h1 class="font-headline text-5xl md:text-7xl font-extrabold text-surface-lowest leading-[1.1] tracking-tighter mb-6">{{ t.contact.hero.title }}</h1>
<p class="text-on-primary-container text-lg max-w-xl leading-relaxed">{{ t.contact.hero.lead }}</p>
</div>
<div class="md:col-span-5 relative">
<div class="aspect-square bg-surface-container-lowest/10 p-1 flex items-center justify-center border border-white/5">
<img class="w-full h-full object-cover grayscale opacity-80" alt="{{ t.contact.hero.heroImgAlt }}" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAD7_a_ujN0cK9wZNKTRUYavmgWHtBDxYZX8QbK8r_1yh_8vQEEcCl_2RL6JvQ0W1Mdc4Ve-w9CpHvJYta949s9awRqXCCxGWMyGJM0XSpt4MlSCcv_NENeD6G1MuUXuiX7VtBP_RIQJx29ibywIU1LMqKdWHhe0MR35RqzhBiN73n3OMQoLy83Cz3lEiRBk6PsqnhArIwqZqFQBlZlpSkvzcPHZ5y8QmjTOezNgHup1j7VOfgEu2ODp4kEeDio-VRCmhSMqsUx4nFF"/>
<div class="absolute -bottom-6 -left-6 bg-secondary p-8 hidden md:block">
<span class="text-surface-lowest font-headline text-4xl font-black">{{ t.contact.hero.sideTitle }}</span>
<p class="text-secondary-container font-label text-xs uppercase tracking-widest mt-2">{{ t.contact.hero.sideSubtitle }}</p>
</div>
</div>
</div>
</div>
</section>
<section class="bg-surface py-24">
<div class="max-w-7xl mx-auto px-6">
<div class="max-w-4xl mx-auto space-y-12">
<div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
<div class="group">
<div class="flex items-center gap-3 mb-4">
<span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">location_on</span>
<h3 class="font-headline font-bold text-primary uppercase tracking-wider text-sm">{{ t.contact.office.hqTitle }}</h3>
</div>
<p class="text-on-surface-variant leading-relaxed">{{ t.contact.office.addressHtml | safe }}</p>
</div>
<div class="group">
<div class="flex items-center gap-3 mb-4">
<span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">call</span>
<h3 class="font-headline font-bold text-primary uppercase tracking-wider text-sm">{{ t.contact.office.commTitle }}</h3>
</div>
<p class="text-on-surface-variant leading-relaxed">
{{ t.contact.office.phoneLabel }} <a class="text-secondary hover:underline font-medium" href="tel:+905333001896">{{ t.footer.phoneDisplay }}</a><br/>
{{ t.contact.office.emailLabel }} <a class="text-secondary hover:underline font-medium" href="mailto:{{ t.footer.email }}">{{ t.footer.email }}</a>
</p>
</div>
</div>
<div class="relative aspect-video bg-surface-container-high overflow-hidden group">
<div class="absolute inset-0 blueprint-grid opacity-30"></div>
<div class="absolute inset-0 flex items-center justify-center">
<img class="w-full h-full object-cover mix-blend-multiply opacity-40 grayscale" alt="" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAPC_qpRiz4hkTi32e1Ew4Bz18rjKu45kuray8zugwUQfVqdUgFUllbnPey1c0YBjy0MZkesAf-AjbxzBmNdnnE0__E0bSGyBH110x_Di1QA8xJNkDmk8f-by7tobaFmlOMXlUgOVfASO67yETpAYIH_QSK79Kpv8TJv3BXs8uDVEDJ0tq9StwoBNTfsRTpA2yMZUHSNYryxCHYR3iCUYd3e7LX5NgJjdeivkPvdoowV5jZ8O4Utfml7ZMPjMpw9itj6Y9yIb1_p9I8"/>
<div class="absolute top-1/3 left-1/2 w-3 h-3 bg-secondary rounded-full animate-pulse"></div>
<div class="absolute top-1/2 left-1/4 w-2 h-2 bg-primary rounded-full"></div>
<div class="absolute top-1/4 left-3/4 w-2 h-2 bg-primary rounded-full"></div>
</div>
<div class="absolute bottom-4 left-4 glass-panel p-4 border border-outline-variant/20">
<span class="font-label text-[10px] uppercase font-bold tracking-[0.3em] text-primary">{{ t.contact.map.statusLabel }}</span>
<div class="flex items-center gap-2 mt-1">
<div class="w-2 h-2 rounded-full bg-green-500"></div>
<span class="text-xs font-medium text-on-surface">{{ t.contact.map.statusText }}</span>
</div>
</div>
</div>
<div class="p-6 bg-surface-container-highest/50 border border-outline-variant/10 relative overflow-hidden">
<div class="absolute top-0 right-0 p-2 font-label text-[8px] text-outline opacity-30 uppercase tracking-tighter">{{ t.contact.specs.ref }}</div>
<div class="flex flex-wrap gap-8">
<div>
<span class="font-label text-[10px] text-on-surface-variant uppercase block mb-1">{{ t.contact.specs.response }}</span>
<span class="font-headline text-lg font-bold text-primary">{{ t.contact.specs.responseValue | safe }}</span>
</div>
<div>
<span class="font-label text-[10px] text-on-surface-variant uppercase block mb-1">{{ t.contact.specs.radius }}</span>
<span class="font-headline text-lg font-bold text-primary">{{ t.contact.specs.radiusValue }}</span>
</div>
<div>
<span class="font-label text-[10px] text-on-surface-variant uppercase block mb-1">{{ t.contact.specs.consult }}</span>
<span class="font-headline text-lg font-bold text-primary">{{ t.contact.specs.consultValue }}</span>
</div>
</div>
</div>
</div>
</div>
</section>
</main>
